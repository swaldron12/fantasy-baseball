# Copy this file to .env locally if you want to use environment variables.
# Do not commit .env. It is ignored by .gitignore.

ENABLE_BEDROCK_ANALYSIS=true
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=760
BEDROCK_TEMPERATURE=0.15
BEDROCK_CHAT_MAX_TOKENS=900
BEDROCK_CHAT_TEMPERATURE=0.2

# Prefer AWS CLI profiles or your shell environment for credentials.
# Do not paste real AWS keys into this file.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
